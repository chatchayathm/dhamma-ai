# ── Embedding provider ────────────────────────────────────────────
# Choose one. Priority: VOYAGE > OPENAI > mock (if neither key is set).
# Voyage handles Thai well via voyage-multilingual-2 (1024 dims).
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-multilingual-2

# Fallback embedding provider.
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small   # 1536 dims

# Force a specific provider regardless of keys: voyage | openai | mock
EMBED_PROVIDER=

# ── Qdrant ────────────────────────────────────────────────────────
# Local Docker default, or a Qdrant Cloud URL + API key for MVP.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=tipitaka_siamrath

# ── Source / fetching ─────────────────────────────────────────────
SOURCE_BASE_URL=https://84000.org
# Be polite to the source server.
FETCH_CONCURRENCY=2
FETCH_DELAY_MS=800

# ── Chunking ──────────────────────────────────────────────────────
MAX_CHUNK_CHARS=1500

# ── Phase 2: RAG query engine (Claude) ────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
RAG_TOP_K=5            # how many chunks to retrieve
RAG_MIN_SCORE=0.4      # discard chunks below this cosine (voyage Thai scores run ~0.4–0.6)
RAG_MIN_CHUNK_CHARS=25 # drop tiny heading-only chunks from results
RAG_MAX_CONTEXT=6000   # max Thai chars of context sent to Claude

# ── Phase 3: REST API ─────────────────────────────────────────────
API_PORT=3001
# comma-separated allowed origins for CORS (frontend). * = allow all (dev only)
API_CORS_ORIGIN=*
