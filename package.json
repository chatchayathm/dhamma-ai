{
  "name": "dhamma-ai-ingestion",
  "version": "0.1.0",
  "description": "Data ingestion pipeline for Dhamma AI — RAG over the Thai Tipitaka (Siam Rath, 45 volumes)",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "ingest": "node src/ingest.js",
    "ingest:dry": "node src/ingest.js --dry-run",
    "ingest:vol1": "node src/ingest.js --volumes=1",
    "ingest:demo": "node src/ingest.js --demo --dry-run --volumes=1",
    "ask": "node src/ask.js",
    "api": "node src/server.js",
    "qdrant:up": "docker compose up -d",
    "qdrant:down": "docker compose down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@qdrant/js-client-rest": "^1.11.0",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "iconv-lite": "^0.6.3",
    "p-limit": "^6.1.0"
  }
}
